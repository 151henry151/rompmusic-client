# Optional: preconfigure the API server URL so users are not prompted on first run.
# If set, the app uses this URL and does not show the "Connect to your server" setup screen.
# Example for a live demo: https://rompmusic.com/api/v1
# EXPO_PUBLIC_API_URL=https://your-server.example.com/api/v1

# Optional: website base URL for Privacy Policy and Terms of Service links in the app.
# Used in Settings and must match your deployed website. Required for store compliance.
# EXPO_PUBLIC_WEBSITE_URL=https://rompmusic.com

# Optional: web base path (e.g. /app for rompmusic.com/app, /client for demo subpath).
# EXPO_PUBLIC_WEB_BASE_URL=/app
